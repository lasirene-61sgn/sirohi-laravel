              "raw": "{\n  \"customer_id\": 1,\n  \"support_type_id\": 1,\n  \"support_category_id\": 1,\n  \"subject\": \"Test Support Ticket\",\n  \"description\": \"This is a test support ticket description.\",\n  \"status\": \"open\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/api/admin/supports",
